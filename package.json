{
  "name": "typingnotion-qa",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed --slow-mo=250",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:prod": "cross-env TARGET=prod playwright test",
    "test:beta": "cross-env TARGET=beta playwright test",
    "test:both": "cross-env TARGET=both playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3"
  }
}
